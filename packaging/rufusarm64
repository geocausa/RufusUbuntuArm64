#!/bin/sh
# Persistence and verified drive-image backup are integrated into the main window.
if [ "${1:-}" = "--persistence" ]; then
  shift
fi
export PYTHONPATH="/usr/lib/rufusarm64${PYTHONPATH:+:${PYTHONPATH}}"
exec /usr/bin/python3 -c 'import sys; from rufusarm64_device_qualify_dialog import run_rufusarm64; raise SystemExit(run_rufusarm64(sys.argv[1:]))' "$@"
